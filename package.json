{
  "name": "conductor-keymap-editor",
  "private": true,
  "version": "0.19.9",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "electron:dev": "concurrently -k -s first \"vite\" \"wait-on http://localhost:5173/conductor-keymap-editor/ && electron .\"",
    "electron:build": "tsc -b && cross-env ELECTRON_BUILD=1 vite build && electron-builder"
  },
  "dependencies": {
    "protobufjs": "^8.6.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.jprabadi.conductor-keymap-editor",
    "productName": "ConductorD Studio",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "target": "dmg",
      "extendInfo": {
        "NSBluetoothAlwaysUsageDescription": "ConductorD Studio uses Bluetooth to configure Conductor keyboards over BLE."
      }
    }
  }
}
